<%# Discover — serendipity mode. Receives from pages.js:
      seed   — random high-quality anime (or null if DB unavailable)
      thread — 18 shuffled picks from the seed's top-40 red thread %>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Discover' }) %>
</head>
<body class="min-h-screen bg-paper font-sans text-ink antialiased">
  <%- include('partials/frame') %>
  <%- include('partials/nav') %>

  <main>
    <% if (seed) { %>
    <%# ——— The draw: dark act, seed card + reroll ——— %>
    <section class="dark-act relative overflow-hidden border-b border-night bg-night text-paper">
      <img src="<%= seed.banner_image_url || seed.cover_image_xl || seed.cover_large %>" alt="" aria-hidden="true" decoding="async"
        class="absolute inset-0 h-full w-full scale-110 object-cover opacity-25 blur-2xl" />
      <div class="grain-overlay absolute inset-0" aria-hidden="true"></div>
      <span class="pointer-events-none absolute -right-8 -top-10 select-none font-serif text-[15rem] font-extrabold leading-none text-paper/[0.05]" aria-hidden="true">発</span>

      <div class="reveal relative mx-auto max-w-6xl px-6 py-14">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <h1>
            <span class="relative inline-block font-serif text-4xl font-extrabold tracking-tight">
              <span class="absolute -inset-x-4 -inset-y-1.5 -rotate-1 bg-sakura" aria-hidden="true"></span>
              <span class="relative text-paper">発見</span>
            </span>
            <span class="jp-sub mt-3">hakken — discover · a random walk along the red thread</span>
          </h1>
          <a href="/discover" class="border border-paper/40 px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] transition-colors hover:border-sakura hover:text-sakura">再抽選 — draw again</a>
        </div>

        <div class="mt-10 flex flex-col gap-8 sm:flex-row sm:items-start">
          <a href="/anime/<%= seed.id %>" class="mx-auto shrink-0 sm:mx-0">
            <img src="<%= seed.cover_image_xl || seed.cover_large %>" alt="" decoding="async" fetchpriority="high"
              class="cover-img cover-lift w-48 border border-paper/25 shadow-[0_24px_60px_-18px_rgba(0,0,0,0.85)]"
              onerror="this.onerror=null;this.src='<%= seed.cover_image_url %>'" />
          </a>
          <div class="min-w-0">
            <p class="meta">today's draw — 本日の一枚</p>
            <h2 class="mt-3 font-serif text-3xl font-extrabold leading-tight tracking-tight text-balance sm:text-4xl">
              <a href="/anime/<%= seed.id %>" class="transition-colors hover:text-sakura"><%= seed.title_romaji %></a>
            </h2>
            <p class="meta mt-3">
              <%= [seed.season_year, seed.format, seed.episodes ? seed.episodes + ' ep' : null].filter(Boolean).join(' · ') %>
              <span class="ml-3 text-sakura tabular-nums"><%= seed.average_score.toFixed(2) %></span>
            </p>
            <% if (seed.synopsis_snip) { %>
            <p class="mt-5 max-w-2xl text-sm leading-relaxed text-paper/75"><%= seed.synopsis_snip %>…</p>
            <% } %>
          </div>
        </div>

        <%# ——— The thread it pulls ——— %>
        <% if (thread.length) { %>
        <div class="mt-12 border-t border-paper/20 pt-8">
          <p class="meta mb-6">its red thread, shuffled — any of the top 40 may surface · 運命の悪戯</p>
          <div class="grid grid-cols-2 gap-x-5 gap-y-8 sm:grid-cols-4 lg:grid-cols-6">
            <% thread.forEach((r) => { %>
            <div>
              <%- include('partials/cover-card', { a: r, dark: true }) %>
              <p class="meta mt-1 text-paper/45">matched on <%= r.signals.replace('synopsis', 'story').replace('+', ' + ') %></p>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </section>
    <% } else { %>
    <section class="mx-auto max-w-6xl px-6 py-24 text-center">
      <p class="font-serif text-3xl font-extrabold tracking-tight">何もない。</p>
      <p class="jp-sub mx-auto mt-2">nanimo nai — the catalog isn't available right now.</p>
    </section>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
