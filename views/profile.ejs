<%# Profile — three acts (matches the home page grammar):
      Act I   paper identity + headline stats (the account's masthead)
      Act II  night library (the list visualized — cover art glows here)
      Act III paper settings (edit username / avatar)
    Receives from src/routes/pages.js:
      user        — the logged-in row (res.locals, set by attachUser)
      anilist     — external_accounts row for AniList, or undefined
      placeholders— [{ key, src }] the built-in avatar gallery
      summary     — profileSummary(): all the real list-derived stats
      errors/values/saved — session-flash state from a previous save
    Everything in Act II is derived from the user's real list; an empty list
    shows an honest invitation, never fabricated numbers. avatarSrc() is
    app.locals. No hyphens in visible copy (house rule). %>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: user.username }) %>
</head>
<body class="min-h-screen bg-paper font-sans text-ink antialiased">
  <%- include('partials/frame') %>
  <%- include('partials/nav') %>

  <%
    var memberSince = '';
    try {
      memberSince = new Date(user.created_at).toLocaleDateString('en-US', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    } catch (e) { memberSince = ''; }
    var curName = (values && values.username) || user.username;

    // One source of truth for how each status reads + colours, reused by the
    // distribution bar, its legend, and the activity feed.
    var STATUS_META = {
      COMPLETED:  { en: 'completed',  jp: '完了',   bar: 'bg-sakura' },
      WATCHING:   { en: 'watching',   jp: '視聴中', bar: 'bg-sakura/70' },
      REWATCHING: { en: 'rewatching', jp: '再視聴', bar: 'bg-sakura-deep' },
      PAUSED:     { en: 'paused',     jp: '中断',   bar: 'bg-paper/60' },
      DROPPED:    { en: 'dropped',    jp: '中止',   bar: 'bg-paper/35' },
      PLANNING:   { en: 'planning',   jp: '予定',   bar: 'bg-paper/20' },
    };

    function ago(iso) {
      try {
        var s = (Date.now() - new Date(iso).getTime()) / 1000;
        if (s < 3600) return Math.max(1, Math.round(s / 60)) + 'm ago';
        if (s < 86400) return Math.round(s / 3600) + 'h ago';
        if (s < 2592000) return Math.round(s / 86400) + 'd ago';
        return new Date(iso).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      } catch (e) { return ''; }
    }
  %>

  <main>
    <%# ═══════════════ ACT I — PAPER (identity) ═══════════════ %>
    <section class="relative overflow-hidden border-b border-ink/80">
      <span class="pointer-events-none absolute -right-10 -top-24 select-none font-serif text-[24rem] font-extrabold leading-none text-sakura/[0.06] sm:text-[30rem]" aria-hidden="true">己</span>
      <div class="pointer-events-none absolute left-[-10%] top-[70%] h-px w-[120%] rotate-[-6deg] bg-sakura/40" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-6xl px-6 pt-14 sm:pt-16">
        <p class="meta">［account］ your thread — member file</p>

        <div class="reveal mt-6 flex flex-col gap-6 sm:flex-row sm:items-end">
          <%- include('partials/avatar', { person: user, cls: 'h-28 w-28 sm:h-32 sm:w-32' }) %>
          <div class="min-w-0 flex-1">
            <h1 class="truncate font-serif text-5xl font-extrabold leading-none tracking-tight sm:text-6xl"><%= user.username %></h1>
            <div class="meta mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 normal-case tracking-normal text-ink/55">
              <% if (memberSince) { %><span>member since <%= memberSince %></span><% } %>
              <% if (user.email) { %><span class="hidden sm:inline">·</span><span><%= user.email %></span><% } %>
              <span class="hidden sm:inline">·</span>
              <% if (anilist) { %>
              <span class="inline-flex items-center gap-1.5 text-sakura"><span class="inline-block h-2 w-2 bg-sakura" aria-hidden="true"></span>AniList linked</span>
              <% } else { %>
              <a href="/auth/anilist" class="underline decoration-sakura underline-offset-2 hover:text-sakura">Connect AniList</a>
              <% } %>
            </div>
          </div>
          <div class="flex shrink-0 items-center gap-4">
            <a href="#settings" class="nav-tab">Settings</a>
            <form method="post" action="/logout" class="inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="nav-tab">Log out</button>
            </form>
          </div>
        </div>

        <%# Headline stat strip — the AniList-style top row, poster-styled. %>
        <%
          var stat = [
            { n: summary.total.toLocaleString('en-US'), jp: '作品', sub: 'sakuhin — titles' },
            { n: summary.episodes.toLocaleString('en-US'), jp: '話数', sub: 'wasuu — episodes' },
            { n: summary.days.toFixed(summary.days >= 100 ? 0 : 1), jp: '日数', sub: 'nissuu — days (est)' },
            { n: summary.meanScore != null ? summary.meanScore.toFixed(1) : '—', jp: '平均', sub: 'heikin — mean score' },
          ];
        %>
        <div class="mt-10 grid grid-cols-2 divide-ink/15 border-t border-ink/80 sm:grid-cols-4 sm:divide-x">
          <% stat.forEach(function (s, i) { %>
          <div class="py-6 <%= i % 2 === 0 ? 'pr-6' : 'pl-6 sm:pl-6' %> <%= i >= 2 ? 'border-t border-ink/15 sm:border-t-0' : '' %> sm:px-6">
            <p class="font-serif text-4xl font-extrabold tracking-tight tabular-nums sm:text-5xl"><%= s.n %></p>
            <p class="mt-2 font-serif text-lg font-bold text-sakura"><%= s.jp %></p>
            <p class="jp-sub"><%= s.sub %></p>
          </div>
          <% }) %>
        </div>
      </div>
    </section>

    <%# ═══════════════ ACT II — NIGHT (library) ═══════════════ %>
    <div class="dark-act border-b border-night bg-night text-paper">
      <div class="mx-auto max-w-6xl px-6 py-16">

        <% if (summary.total === 0) { %>
        <%# Honest empty state — no fake numbers, just the on-ramp. %>
        <div class="relative overflow-hidden border border-paper/15 px-8 py-16 text-center">
          <span class="pointer-events-none absolute -right-6 -top-10 select-none font-serif text-[14rem] font-extrabold leading-none text-paper/[0.05]" aria-hidden="true">空</span>
          <p class="font-serif text-3xl font-bold">あなたの記録はまだ空です</p>
          <p class="jp-sub">anata no kiroku wa mada kara desu — your list is empty</p>
          <p class="mx-auto mt-6 max-w-md text-sm text-paper/70">Track an anime and this page fills with your stats, your favorites, and the taste the red thread follows.</p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <a href="/catalog" class="bg-sakura px-6 py-3 font-mono text-xs uppercase tracking-[0.2em] text-paper transition-colors hover:bg-sakura-deep">Browse the catalog</a>
            <a href="/discover" class="border border-paper/40 px-6 py-3 font-mono text-xs uppercase tracking-[0.2em] text-paper transition-colors hover:border-sakura hover:text-sakura">Discover something</a>
          </div>
        </div>
        <% } else { %>

        <div class="flex items-end justify-between gap-4">
          <div>
            <h2 class="font-serif text-3xl font-bold tracking-tight">視聴記録</h2>
            <p class="jp-sub">shichou kiroku — your library</p>
          </div>
          <span class="meta text-paper/55"><%= summary.total.toLocaleString('en-US') %> tracked</span>
        </div>

        <div class="mt-10 grid gap-12 lg:grid-cols-2">
          <%# ——— Status distribution ——— %>
          <div>
            <p class="meta text-paper/55">distribution — 内訳</p>
            <div class="mt-3 flex h-4 w-full overflow-hidden rounded-sm bg-paper/10">
              <% summary.statusOrder.forEach(function (st) { var n = summary.byStatus[st] || 0; if (!n) return; %>
              <div class="<%= STATUS_META[st].bar %>" style="width: <%= (n / summary.total * 100).toFixed(2) %>%" title="<%= STATUS_META[st].en %>: <%= n %>"></div>
              <% }) %>
            </div>
            <ul class="mt-5 grid grid-cols-2 gap-x-6 gap-y-2">
              <% summary.statusOrder.forEach(function (st) { var n = summary.byStatus[st] || 0; %>
              <li class="flex items-center gap-2.5 <%= n ? '' : 'opacity-40' %>">
                <span class="inline-block h-2.5 w-2.5 shrink-0 <%= STATUS_META[st].bar %>" aria-hidden="true"></span>
                <span class="meta text-paper/70"><%= STATUS_META[st].en %></span>
                <span class="ml-auto font-serif text-sm font-bold tabular-nums"><%= n %></span>
              </li>
              <% }) %>
            </ul>
          </div>

          <%# ——— Score histogram ——— %>
          <div>
            <p class="meta text-paper/55">ratings — 評価分布</p>
            <% if (summary.scoredCount === 0) { %>
            <p class="mt-6 text-sm text-paper/50">No ratings yet. Score a title and the shape of your taste shows up here.</p>
            <% } else { %>
            <div class="mt-3 flex h-32 items-end gap-1.5">
              <% summary.histogram.forEach(function (h) { %>
              <div class="group flex flex-1 flex-col items-center justify-end" title="<%= h.score %>/10 · <%= h.n %>">
                <span class="mb-1 font-mono text-[0.6rem] text-paper/50 tabular-nums opacity-0 transition-opacity group-hover:opacity-100"><%= h.n %></span>
                <div class="w-full bg-sakura/80 transition-colors group-hover:bg-sakura" style="height: <%= h.n ? Math.max(3, h.n / summary.histMax * 100) : 0 %>%"></div>
              </div>
              <% }) %>
            </div>
            <div class="mt-2 flex gap-1.5">
              <% summary.histogram.forEach(function (h) { %>
              <span class="flex-1 text-center font-mono text-[0.6rem] text-paper/45 tabular-nums"><%= h.score %></span>
              <% }) %>
            </div>
            <p class="meta mt-4 text-paper/55">mean <span class="text-sakura"><%= summary.meanScore.toFixed(2) %></span> over <%= summary.scoredCount %> rated</p>
            <% } %>
          </div>
        </div>

        <%# ——— Top genres ——— %>
        <% if (summary.genres.length) { %>
        <div class="mt-12">
          <p class="meta text-paper/55">most watched genres — 傾向</p>
          <ul class="mt-4 grid gap-x-10 gap-y-3 sm:grid-cols-2">
            <% summary.genres.forEach(function (g) { %>
            <li class="flex items-center gap-3">
              <span class="w-28 shrink-0 truncate font-serif text-sm font-bold"><%= g.name %></span>
              <span class="relative h-2 flex-1 overflow-hidden rounded-sm bg-paper/10">
                <span class="absolute inset-y-0 left-0 bg-sakura" style="width: <%= (g.n / summary.genreMax * 100).toFixed(1) %>%"></span>
              </span>
              <span class="w-8 shrink-0 text-right font-mono text-xs text-paper/55 tabular-nums"><%= g.n %></span>
            </li>
            <% }) %>
          </ul>
        </div>
        <% } %>

        <%# ——— Favorites ——— %>
        <% if (summary.favorites.length) { %>
        <div class="mt-14">
          <div class="flex items-end justify-between gap-4">
            <div>
              <h3 class="font-serif text-2xl font-bold tracking-tight">お気に入り</h3>
              <p class="jp-sub">okiniiri — favorites</p>
            </div>
            <span class="meta text-paper/55"><%= summary.favoritesCount %></span>
          </div>
          <div class="mt-6 grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6">
            <% summary.favorites.forEach(function (a) { %>
            <%- include('partials/cover-card', { a: a, dark: true }) %>
            <% }) %>
          </div>
        </div>
        <% } %>

        <%# ——— Recent activity ——— %>
        <% if (summary.recent.length) { %>
        <div class="mt-14">
          <h3 class="font-serif text-2xl font-bold tracking-tight">最近の動き</h3>
          <p class="jp-sub">saikin no ugoki — recent activity</p>
          <ul class="mt-6 divide-y divide-paper/10 border-y border-paper/10">
            <% summary.recent.forEach(function (a) { var m = STATUS_META[a.status] || { en: a.status, bar: 'bg-paper/40' }; %>
            <li>
              <a href="/anime/<%= a.id %>" class="group flex items-center gap-4 py-3">
                <span class="h-12 w-9 shrink-0 overflow-hidden border border-paper/20 bg-paper/5">
                  <img src="<%= a.cover_image_url %>" alt="" loading="lazy" class="cover-img h-full w-full" />
                </span>
                <span class="min-w-0 flex-1">
                  <span class="block truncate font-serif text-sm font-bold transition-colors group-hover:text-sakura"><%= a.title_romaji %></span>
                  <span class="meta mt-0.5 flex items-center gap-2 text-paper/55">
                    <span class="inline-block h-1.5 w-1.5 <%= m.bar %>" aria-hidden="true"></span><%= m.en %>
                    <% if (a.score != null) { %><span>· <%= (a.score / 10).toFixed(1) %>/10</span><% } %>
                    <% if (a.episodes_watched) { %><span class="hidden sm:inline">· <%= a.episodes_watched %><%= a.episodes ? '/' + a.episodes : '' %> ep</span><% } %>
                  </span>
                </span>
                <span class="meta shrink-0 text-paper/45"><%= ago(a.updated_at) %></span>
              </a>
            </li>
            <% }) %>
          </ul>
        </div>
        <% } %>

        <% } %>
      </div>
    </div>

    <%# ═══════════════ ACT III — PAPER (settings) ═══════════════ %>
    <section id="settings" class="relative overflow-hidden">
      <span class="pointer-events-none absolute -right-8 -top-12 select-none font-serif text-[13rem] font-extrabold leading-none text-ink/[0.04]" aria-hidden="true">設</span>
      <div class="relative mx-auto max-w-2xl px-6 py-16">
        <h2>
          <span class="relative inline-block font-serif text-3xl font-extrabold tracking-tight">
            <span class="absolute -inset-x-4 -inset-y-1.5 -rotate-1 bg-sakura" aria-hidden="true"></span>
            <span class="relative text-paper">設定</span>
          </span>
          <span class="jp-sub mt-3">settei — your name and picture</span>
        </h2>

        <% if (saved) { %>
        <div class="mt-8 border-l-2 border-sakura bg-sakura/5 px-4 py-3" role="status">
          <p class="text-sm text-sakura-deep">Saved.</p>
        </div>
        <% } %>
        <% if (errors && errors.length) { %>
        <div class="mt-8 border-l-2 border-sakura bg-sakura/5 px-4 py-3" role="alert">
          <% errors.forEach(function (e) { %><p class="text-sm text-sakura-deep"><%= e %></p><% }) %>
        </div>
        <% } %>

        <form method="post" action="/profile" enctype="multipart/form-data" class="mt-8 space-y-8">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <label class="block">
            <span class="meta">username</span>
            <input type="text" name="username" value="<%= curName %>" required minlength="3" maxlength="20" autocomplete="username"
              class="mt-1.5 w-full border border-ink/80 bg-paper px-4 py-3 text-sm text-ink placeholder:text-ink/40 focus:border-sakura focus:outline-none" />
            <span class="meta mt-1 block normal-case tracking-normal text-ink/45">3–20 characters · letters, numbers, _ or -</span>
          </label>

          <fieldset>
            <legend class="meta">choose a look</legend>
            <div class="mt-3 flex flex-wrap gap-4">
              <% placeholders.forEach(function (p) { %>
              <label class="cursor-pointer">
                <input type="radio" name="placeholder" value="<%= p.key %>" class="peer sr-only" <%= user.avatar === p.key ? 'checked' : '' %> />
                <span class="block rounded-sm border-2 border-transparent p-1 transition-colors peer-checked:border-sakura peer-focus-visible:border-sakura hover:border-ink/30">
                  <span class="enso-mask block h-16 w-16 overflow-hidden bg-paper">
                    <img src="<%= p.src %>" alt="" class="h-full w-full object-cover" />
                  </span>
                </span>
              </label>
              <% }) %>
            </div>
          </fieldset>

          <label class="block">
            <span class="meta">or upload your own</span>
            <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp"
              class="mt-1.5 block w-full text-sm text-ink/70 file:mr-4 file:border file:border-ink/80 file:bg-paper file:px-4 file:py-2 file:font-mono file:text-xs file:uppercase file:tracking-[0.18em] file:text-ink hover:file:border-sakura hover:file:text-sakura" />
            <span class="meta mt-1 block normal-case tracking-normal text-ink/45">JPG, PNG or WebP · up to 2 MB</span>
          </label>

          <button type="submit" class="w-full bg-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.2em] text-paper transition-colors hover:bg-sakura">
            save changes
          </button>
        </form>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
