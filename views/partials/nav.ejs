<%# Site chrome: micro-type ticker strip + masthead nav.
    `active` local marks the current tab ('home' | 'catalog' | 'docs' | '').
    Tabs for routes that don't exist yet render as inert .nav-tab-soon spans —
    they become real <a> links the same commit their route ships. %>
<% var act = typeof active !== 'undefined' ? active : ''; %>
<div class="hidden border-b border-ink/80 sm:block">
  <div class="meta mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-1.5">
    <span>OtakuGuide — vol.01</span>
    <span>アニメ追跡＋推薦</span>
    <span class="hidden md:inline">35°42′08″N 139°46′27″E</span>
    <span class="hidden lg:inline">est. 2026 — tokyo / localhost</span>
    <span class="text-sakura">桜</span>
  </div>
</div>
<header class="border-b border-ink/80 bg-paper">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="group flex items-center gap-3">
      <%- include('enso', { id: 'nav', cls: 'enso-spin h-10 w-10', color: '#E03C42', draw: true, line: '#16120F' }) %>
      <span class="flex items-baseline gap-2">
        <span class="font-serif text-xl font-extrabold tracking-tight">OtakuGuide</span>
        <span class="meta hidden sm:inline">オタクガイド</span>
      </span>
    </a>
    <div class="flex items-center gap-6">
      <a href="/" <%- act === 'home' ? 'aria-current="page"' : '' %> class="nav-tab">Home</a>
      <a href="/catalog" <%- act === 'catalog' ? 'aria-current="page"' : '' %> class="nav-tab">Catalog</a>
      <a href="/airing" <%- act === 'airing' ? 'aria-current="page"' : '' %> class="nav-tab">Airing</a>
      <a href="/discover" <%- act === 'discover' ? 'aria-current="page"' : '' %> class="nav-tab">Discover</a>
      <a href="/library" <%- act === 'library' ? 'aria-current="page"' : '' %> class="nav-tab hidden sm:inline">Library</a>
      <%# Account state. res.locals.user is set by attachUser on every request.
          Logged in → just the avatar (NO username on the masthead), which opens
          a dropdown to Profile / Notifications / Settings. It's a native
          <details> menu (works with no JS); account-menu.js only adds
          outside-click / Escape close. Logout lives inside Settings, nowhere
          else. Logged out → a log-in link. %>
      <span class="flex items-center gap-4 border-l border-ink/30 pl-6">
        <% if (typeof user !== 'undefined' && user) { %>
        <details class="account-menu relative">
          <summary aria-haspopup="menu" aria-label="Account menu" title="Account">
            <%- include('avatar', { person: user, cls: 'h-8 w-8' }) %>
          </summary>
          <div role="menu" class="absolute right-0 top-full z-50 mt-3 w-52 border border-paper/15 bg-night py-2 text-paper shadow-[0_16px_40px_-12px_rgba(0,0,0,0.7)]">
            <a href="/profile" role="menuitem" class="menu-item">
              <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M4.5 19a7.5 7.5 0 0 1 15 0"/></svg>
              Profile
            </a>
            <span role="menuitem" aria-disabled="true" class="menu-item-soon" title="Coming soon">
              <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 1 0-12 0c0 7-2.5 8-2.5 8h17S18 15 18 8"/><path d="M10.5 20.5a2 2 0 0 0 3 0"/></svg>
              Notifications
              <span class="meta ml-auto text-paper/30">soon</span>
            </span>
            <a href="/settings" role="menuitem" class="menu-item">
              <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2.5v3M12 18.5v3M21.5 12h-3M5.5 12h-3M18.7 5.3l-2.1 2.1M7.4 16.6l-2.1 2.1M18.7 18.7l-2.1-2.1M7.4 7.4 5.3 5.3"/></svg>
              Settings
            </a>
          </div>
        </details>
        <% } else { %>
        <a href="/login" <%- act === 'login' ? 'aria-current="page"' : '' %> class="nav-tab">Log in</a>
        <% } %>
      </span>
    </div>
  </nav>
</header>
<%# Progressive enhancement for the account dropdown: close on outside click /
    Escape. The menu already opens/closes via the native <details>; this only
    makes it feel finished. No-ops when there's no menu (logged out). %>
<script src="/js/account-menu.js" defer></script>
