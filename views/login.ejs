<%# Login — sign in to OtakuGuide. Receives from src/routes/auth.js:
      errors (array of strings), values ({ email } to repopulate).
      res.locals.csrfToken is set by the csrf middleware. No JS; a plain POST. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Log in' }) %>
</head>
<body class="min-h-screen bg-paper font-sans text-ink antialiased">
  <%- include('partials/frame') %>
  <%- include('partials/nav') %>

  <main class="relative mx-auto max-w-md overflow-hidden px-6 py-16">
    <span class="pointer-events-none absolute -right-8 -top-10 select-none font-serif text-[12rem] font-extrabold leading-none text-ink/[0.04]" aria-hidden="true">糸</span>

    <div class="reveal relative">
      <h1>
        <span class="relative inline-block font-serif text-4xl font-extrabold tracking-tight">
          <span class="absolute -inset-x-4 -inset-y-1.5 -rotate-1 bg-sakura" aria-hidden="true"></span>
          <span class="relative text-paper">入室</span>
        </span>
        <span class="jp-sub mt-3">nyuushitsu — sign in · pick the thread back up</span>
      </h1>

      <% if (errors && errors.length) { %>
      <div class="mt-8 border-l-2 border-sakura bg-sakura/5 px-4 py-3" role="alert">
        <% errors.forEach((e) => { %>
        <p class="text-sm text-sakura-deep"><%= e %></p>
        <% }) %>
      </div>
      <% } %>

      <form method="post" action="/login" class="mt-8 space-y-5">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <label class="block">
          <span class="meta">email</span>
          <input type="email" name="email" value="<%= values.email || '' %>" required autocomplete="email"
            class="mt-1.5 w-full border border-ink/80 bg-paper px-4 py-3 text-sm text-ink placeholder:text-ink/40 focus:border-sakura focus:outline-none" />
        </label>

        <label class="block">
          <span class="meta">password</span>
          <input type="password" name="password" required autocomplete="current-password"
            class="mt-1.5 w-full border border-ink/80 bg-paper px-4 py-3 text-sm text-ink placeholder:text-ink/40 focus:border-sakura focus:outline-none" />
        </label>

        <button type="submit" class="w-full bg-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.2em] text-paper transition-colors hover:bg-sakura">
          log in
        </button>
      </form>

      <%# AniList sign-in: an EQUAL option by design (project rule — the AniList
          button must never be louder than email, or we've gated the app). Same
          size/height as the ink button above; outlined rather than filled so the
          two read as peers, not primary+secondary. GET is correct here: it just
          starts the OAuth redirect; the state change happens server-side. %>
      <div class="mt-6 flex items-center gap-3">
        <span class="h-px flex-1 bg-ink/15"></span>
        <span class="meta text-ink/40">or</span>
        <span class="h-px flex-1 bg-ink/15"></span>
      </div>
      <a href="/auth/anilist" class="mt-6 flex w-full items-center justify-center border-2 border-ink px-6 py-3 font-mono text-xs uppercase tracking-[0.2em] text-ink transition-colors hover:border-sakura hover:text-sakura">
        continue with AniList
      </a>

      <p class="meta mt-8 normal-case tracking-normal text-ink/55">
        New here?
        <a href="/signup" class="underline decoration-sakura underline-offset-2 hover:text-sakura">Create an account</a>.
      </p>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
