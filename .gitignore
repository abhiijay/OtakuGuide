db/import-progress.json
db/source-backfill-progress.json
db/country-sweep-progress.json
db/country-sweep-report.jsonl

# offline-database snapshot — re-downloaded by src/offline-db.js as needed (~58 MB)
db/anime-offline-database.json

# Logs
logs/
*.log

# macOS / IDE noise
.DS_Store
.vscode/
.idea/
