# Dependencies
node_modules/

# Secrets — never commit
.env

# Compiled CSS (regenerated by Tailwind)
public/css/styles.css

# SQLite DB files
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

