# Server
PORT=3000

# Session — generate a long random string for this; required to boot
# Quick way: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# AniList OAuth
# Register an app at https://anilist.co/settings/developer
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
ANILIST_REDIRECT_URI=http://localhost:3000/auth/anilist/callback
