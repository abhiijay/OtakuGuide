{
  "name": "otakuguide",
  "version": "0.1.0",
  "description": "A minimalist anime tracker and recommender with embedding-based similarity",
  "private": true,
  "license": "MIT",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npm run build:css && node server.js",
    "dev": "concurrently --names \"server,tailwind\" --prefix-colors \"red,gray\" \"npm:dev:server\" \"npm:dev:css\"",
    "dev:server": "nodemon server.js",
    "dev:css": "tailwindcss -i ./styles/input.css -o ./public/css/styles.css --watch",
    "build:css": "tailwindcss -i ./styles/input.css -o ./public/css/styles.css --minify",
    "init-db": "node scripts/init-db.js",
    "test:round-trip": "node scripts/test-round-trip.js",
    "test:recommender": "node src/recommender.js",
    "import": "node scripts/import-anime.js",
    "refresh": "node scripts/import-anime.js --refresh && npm run sync:recent && npm run sweep:country && npm run backfill:popularity && npm run seed:genres && npm run backfill:source && npm run flag:adult && npm run enrich:art",
    "sync:recent": "node scripts/sync-recent.js",
    "enrich:art": "node scripts/enrich-art.js",
    "backfill:source": "node scripts/backfill-source.js",
    "backfill:popularity": "node scripts/backfill-popularity.js",
    "seed:genres": "node scripts/seed-genres-from-tags.js",
    "sweep:country": "node scripts/sweep-country.js",
    "flag:adult": "node scripts/flag-adult.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.10"
  }
}
